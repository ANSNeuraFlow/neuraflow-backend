{
  "name": "neuraflow-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Backend for NeuraFlow.",
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "husky",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "prestart": "pnpm kysely:migrate:latest && pnpm kysely:seed:run",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug 0.0.0.0:9229 --watch",
    "start:prod": "node dist/src/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typecheck": "tsc --noEmit -p tsconfig.build.json --incremental false",
    "typecheck:watch": "tsc --noEmit -p tsconfig.build.json --watch --incremental false",
    "kysely": "kysely",
    "kysely:migrate:latest": "kysely migrate:latest",
    "kysely:migrate:up": "kysely migrate:up",
    "kysely:migrate:down": "kysely migrate:down",
    "kysely:migrate:rollback:all": "kysely migrate:rollback --all",
    "kysely:prod": "kysely --config dist/kysely.config.js",
    "kysely:prod:migrate:latest": "pnpm run kysely:prod migrate:latest",
    "kysely:prod:migrate:up": "pnpm run kysely:prod migrate:up",
    "kysely:prod:migrate:down": "pnpm run kysely:prod migrate:down",
    "kysely:prod:migrate:rollback:all": "pnpm run kysely:prod migrate:rollback --all",
    "kysely:seed:run": "kysely seed:run",
    "doc:generate": "npx compodoc -p tsconfig.json -n \"Documentation\"",
    "doc:serve": "npx compodoc -p tsconfig.json -n \"Documentation\" -s",
    "lint:eslint": "eslint --ext .js,.ts src",
    "lint:eslint:fix": "pnpm lint:eslint --fix",
    "lint:prettier": "prettier --check src",
    "lint:prettier:fix": "prettier --write .",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "lint:fix": "pnpm lint:eslint:fix && pnpm lint:prettier:fix"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@nanogiants/nestjs-swagger-api-exception-decorator": "^1.7.2",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/devtools-integration": "^0.2.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.16",
    "@ngneat/falso": "^8.0.2",
    "@scalar/nestjs-api-reference": "^0.5.14",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "dataloader": "^2.2.3",
    "envalid": "^8.1.1",
    "find-config": "^1.0.0",
    "helmet": "^8.1.0",
    "jose": "^6.2.1",
    "ky": "^1.14.3",
    "kysely": "^0.28.12",
    "kysely-ctl": "^0.15.3",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@compodoc/compodoc",
      "@nestjs/core",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "nestjs-pino",
      "unrs-resolver"
    ]
  }
}
